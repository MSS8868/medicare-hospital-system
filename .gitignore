# ─────────────────────────────────────────────────────────────────────────────
# MediCare Hospital Management System — .gitignore
# Place this file at the ROOT of your project (same level as backend/ frontend/)
# ─────────────────────────────────────────────────────────────────────────────
 
 
# ══════════════════════════════════════════════════════
# DEPENDENCIES — never commit node_modules
# ══════════════════════════════════════════════════════
node_modules/
**/node_modules/
.pnp
.pnp.js
.yarn/
 
 
# ══════════════════════════════════════════════════════
# ENVIRONMENT FILES — contain passwords, secrets, API keys
# CRITICAL: never commit these to GitHub
# ══════════════════════════════════════════════════════
.env
.env.local
.env.development
.env.production
.env.staging
.env.test
**/.env
**/.env.local
**/.env.development
**/.env.production
**/.env.staging
 
# Keep example files (safe to commit — no real secrets)
!.env.example
!**/.env.example
 
 
# ══════════════════════════════════════════════════════
# DATABASE — SQLite files (if you ever switch back)
# ══════════════════════════════════════════════════════
*.db
*.sqlite
*.sqlite3
hospital.db
backend/*.db
backend/**/*.db
 
 
# ══════════════════════════════════════════════════════
# LOGS
# ══════════════════════════════════════════════════════
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
backend/logs/
backend/logs/*.log
combined.log
error.log
 
 
# ══════════════════════════════════════════════════════
# UPLOADS — user-uploaded files (store on S3/Cloudinary in production)
# ══════════════════════════════════════════════════════
backend/uploads/
uploads/
*.pdf
*.jpg
*.jpeg
*.png
*.gif
*.mp4
 
# Keep the uploads directory itself (so git tracks the folder)
!backend/uploads/.gitkeep
 
 
# ══════════════════════════════════════════════════════
# REACT BUILD OUTPUT
# ══════════════════════════════════════════════════════
frontend/build/
build/
dist/
 
 
# ══════════════════════════════════════════════════════
# REACT / CRA CACHE
# ══════════════════════════════════════════════════════
frontend/.cache/
.eslintcache
.stylelintcache
 
 
# ══════════════════════════════════════════════════════
# OS GENERATED FILES
# ══════════════════════════════════════════════════════
 
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride
Icon?
 
# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk
 
# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*
 
 
# ══════════════════════════════════════════════════════
# EDITOR & IDE FILES
# ══════════════════════════════════════════════════════
 
# VS Code
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example
 
# JetBrains (WebStorm, IntelliJ)
.idea/
*.iml
*.iws
*.ipr
.idea_modules/
 
# Vim / Emacs
*.swp
*.swo
*.swn
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
 
# Sublime Text
*.tmlanguage.cache
*.tmPreferences.cache
*.stTheme.cache
*.sublime-workspace
 
 
# ══════════════════════════════════════════════════════
# TESTING
# ══════════════════════════════════════════════════════
coverage/
.nyc_output/
*.lcov
jest_html_reporters_cache/
 
 
# ══════════════════════════════════════════════════════
# PACKAGE MANAGER LOCKS
# (keep package-lock.json but ignore yarn.lock if not using yarn)
# ══════════════════════════════════════════════════════
# Uncomment the one you DON'T use:
# yarn.lock         # uncomment if you use npm
# package-lock.json  # uncomment if you use yarn
 
 
# ══════════════════════════════════════════════════════
# MISC
# ══════════════════════════════════════════════════════
*.pem
*.key
*.cert
*.p12
*.pfx
.npm/
.node_repl_history
.temp/
.tmp/
tmp/
temp/
 